<% layout('layouts/boilerplate') -%>

<div class="row mt-5 mb-5">
    <div class="col-lg-6 offset-lg-3 col-md-8 offset-md-2">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-center">
            <div class="card-header bg-success text-white py-4 border-0">
                <i class="fa-solid fa-circle-check fs-1 mb-3 mt-2"></i>
                <h2 class="fw-bold mb-1">Booking Confirmed!</h2>
            </div>
            <div class="card-body p-5">
                <p class="fs-5 text-muted mb-4">You're all set! Your trip to <strong><%= booking.listingId.title %></strong> is booked.</p>
                
                <div class="bg-light p-4 rounded-4 text-start mb-4" style="background-color: #f8f9fa !important;">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Trip Details</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted fw-semibold">Check-in</span>
                        <span class="text-dark fw-bold"><%= booking.checkInDate.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted fw-semibold">Checkout</span>
                        <span class="text-dark fw-bold"><%= booking.checkOutDate.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                    </div>
                    <div class="d-flex justify-content-between mt-3 pt-3 border-top border-secondary-subtle">
                        <span class="text-dark fw-bold fs-5">Total Paid</span>
                        <span class="text-dark fw-bold fs-5">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                    </div>
                </div>
                
                <div class="d-flex gap-3 justify-content-center mt-5 mb-2">
                    <a href="/bookings" class="btn btn-outline-dark px-4 py-2 rounded-pill fw-semibold border-2">View My Trips</a>
                    <a href="/listings" class="btn btn-danger px-4 py-2 rounded-pill fw-semibold" style="background-color: #e61e4d; border:none;">Keep Exploring</a>
                </div>
            </div>
        </div>
    </div>
</div>
