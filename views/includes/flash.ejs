<% if(success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show col-lg-6 offset-lg-3 col-md-10 offset-md-1 mt-3 shadow-sm border-0 rounded-4 py-3" role="alert" style="background-color: #f0fff4; color: #1a5e37; border-left: 5px solid #2ecc71 !important;">
        <div class="d-flex align-items-center">
            <div class="bg-success rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background-color: #2ecc71 !important;">
                <i class="fa-solid fa-check text-white small"></i>
            </div>
            <div class="fw-semibold"><%= success %></div>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<% if(error && error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show col-lg-6 offset-lg-3 col-md-10 offset-md-1 mt-3 shadow-sm border-0 rounded-4 py-3" role="alert" style="background-color: #fff5f5; color: #9b2c2c; border-left: 5px solid #e53e3e !important;">
        <div class="d-flex align-items-center">
            <div class="bg-danger rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background-color: #e53e3e !important;">
                <i class="fa-solid fa-xmark text-white small"></i>
            </div>
            <div class="fw-semibold"><%= error %></div>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>
