<% layout('layouts/boilerplate') -%>

<div class="row mt-5 mb-5">
    <div class="col-lg-4 offset-lg-4 col-md-6 offset-md-3">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="bg-danger py-4 text-center" style="background: linear-gradient(135deg, #FF385C 0%, #BD1E59 100%) !important;">
                <h2 class="text-white fw-bold mb-0">StayHub</h2>
                <p class="text-white-50 small mb-0 mt-1">Welcome back, Traveler!</p>
            </div>
            <div class="card-body p-4 p-md-5">
                <form action="/login" method="POST" class="needs-validation" novalidate>
                    <div class="mb-4">
                        <label for="username" class="form-label fw-semibold small text-muted text-uppercase mb-1" style="letter-spacing: 0.5px;">Username</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 rounded-start-3"><i class="fa-regular fa-user text-muted"></i></span>
                            <input name="username" id="username" type="text" class="form-control bg-light border-start-0 rounded-end-3 py-2 px-3 shadow-none" placeholder="Enter your username" required>
                            <div class="invalid-feedback">Username is required.</div>
                        </div>
                    </div>
                    
                    <div class="mb-5">
                        <label for="password" class="form-label fw-semibold small text-muted text-uppercase mb-1" style="letter-spacing: 0.5px;">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 rounded-start-3"><i class="fa-solid fa-lock text-muted"></i></span>
                            <input name="password" id="password" type="password" class="form-control bg-light border-start-0 rounded-end-3 py-2 px-3 shadow-none" placeholder="Enter your password" required>
                            <div class="invalid-feedback">Password is required.</div>
                        </div>
                    </div>

                    <button class="btn btn-danger w-100 py-3 fw-bold rounded-3 shadow-sm hover-up border-0 fs-5 mb-4" style="background: linear-gradient(to right, #e61e4d 0%, #e31c5f 50%, #d70466 100%); transition: all 0.3s ease;">
                        Log In
                    </button>
                    
                    <div class="text-center">
                        <span class="text-muted small">New to StayHub?</span>
                        <a href="/signup" class="text-danger small fw-bold text-decoration-none border-bottom border-danger ms-1">Create an account</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
